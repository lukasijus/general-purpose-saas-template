# ============================================================================
# Application
# ============================================================================
APP_NAME="General Purpose SaaS Template"
APP_ENV=development
DEBUG=true

# ============================================================================
# GUI
# ============================================================================
VITE_API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME="General Purpose SaaS Template"
GUI_APP_URL=http://localhost:5173

# ============================================================================
# Landing
# ============================================================================
LANDING_PORT=5174

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=driver://user:password@localhost:5432/db_name
UPLOAD_STORAGE_PATH=./data/uploads

# ============================================================================
# JWT
# ============================================================================
JWT_ACCESS_SECRET=super-long-random-secret
JWT_REFRESH_SECRET=another-super-long-random-secret
ACCESS_TOKEN_EXPIRE=900
REFRESH_TOKEN_EXPIRE=1800

# ============================================================================
# SSO
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# Security
# ============================================================================
PASSWORD_HASH_SCHEME=argon2
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ============================================================================
# Email
# ============================================================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=...
SMTP_PASSWORD=...
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
